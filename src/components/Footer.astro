---
import { MASTHEAD, MASTHEAD_KR, PUBLISHER, url } from '../consts';

const today = new Date();
---

<footer>
	<div class="inner">
		<hr class="rule" />
		<div class="colophon">
			<div>
				<span class="kicker">[ {PUBLISHER} ]</span>
			</div>
			<div class="mast">
				<span class="footer-title">{MASTHEAD}</span>
				<span class="kicker kicker--faint">{MASTHEAD_KR}</span>
			</div>
			<div class="meta kicker kicker--faint">
				<a href={url('/rss.xml')}>RSS</a>
				<span>&copy; {today.getFullYear()}</span>
			</div>
		</div>
	</div>
</footer>

<style>
	footer {
		max-width: var(--page-max);
		margin: 5rem auto 0;
		padding: 0 var(--page-pad) 3rem;
	}
	.colophon {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 1rem;
		padding-top: 1.2rem;
	}
	.mast {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.3rem;
		text-align: center;
	}
	.footer-title {
		font-family: var(--serif);
		font-size: 1.3rem;
		font-weight: 700;
	}
	.meta {
		display: flex;
		gap: 1.6em;
	}
	.meta a:hover {
		opacity: 0.5;
	}
	@media (max-width: 600px) {
		.colophon {
			flex-direction: column;
			align-items: center;
			gap: 1.2rem;
		}
	}
</style>
