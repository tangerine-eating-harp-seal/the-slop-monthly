---
import { MASTHEAD, MASTHEAD_KR, url } from '../consts';

// Slim edition bar + nav. The big masthead lives on the cover (index page);
// inner pages get the compact version via the `compact` prop.
interface Props {
	compact?: boolean;
}

const { compact = false } = Astro.props;
const now = new Date();
const edition = now.toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
---

<header>
	<div class="edition-bar">
		<span class="kicker kicker--faint">{MASTHEAD_KR}</span>
		<nav class="kicker">
			<a href={url('/')}>Cover</a>
			<a href={url('/blog')}>Index</a>
			<a href={url('/about')}>Colophon</a>
		</nav>
		<span class="kicker kicker--faint edition">{edition}</span>
	</div>
	<hr class="rule" />
	{
		!compact && (
			<a class="masthead-link" href={url('/')}>
				<h1 class="masthead">{MASTHEAD}</h1>
			</a>
		)
	}
</header>

<style>
	header {
		max-width: var(--page-max);
		margin: 0 auto;
		padding: 1.4rem var(--page-pad) 0;
	}
	.edition-bar {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 1rem;
		padding-bottom: 0.9rem;
	}
	nav {
		display: flex;
		gap: 2.2em;
	}
	nav a:hover {
		opacity: 0.5;
	}
	.masthead-link {
		display: block;
	}
	.masthead {
		font-size: clamp(3rem, 9vw, 6.4rem);
		font-weight: 500;
		text-align: center;
		letter-spacing: 0.01em;
		line-height: 1;
		margin: 0.35em 0 0.28em;
	}
	@media (max-width: 600px) {
		.edition {
			display: none;
		}
	}
</style>
