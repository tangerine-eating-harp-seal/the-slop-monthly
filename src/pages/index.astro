---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import {
	MASTHEAD,
	MASTHEAD_KR,
	PUBLISHER,
	SITE_DESCRIPTION,
	SITE_TITLE,
	TAGLINE,
	issueNumber,
	url,
} from '../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => a.data.pubDate.valueOf() - b.data.pubDate.valueOf(),
);
const issues = posts.map((post, i) => ({ post, no: issueNumber(i + 1) }));
const latest = issues[issues.length - 1];
const backIssues = issues.slice(0, -1).reverse().slice(0, 6);

const now = new Date();
const edition = now.toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<main class="cover">
			<div class="side-tab side-tab--left" aria-hidden="true"></div>
			<div class="side-tab side-tab--right" aria-hidden="true"></div>

			<p class="kicker publisher">[ {PUBLISHER} ]</p>
			<h1 class="display masthead">
				<span class="masthead-layer masthead-en">{MASTHEAD}</span>
				<span class="masthead-layer masthead-kr" aria-hidden="true">{MASTHEAD_KR}</span>
				<span class="masthead-layer masthead-en masthead-en-return" aria-hidden="true">{MASTHEAD}</span>
			</h1>
			<p class="kicker kicker--faint subtitle">{MASTHEAD_KR} — {edition}</p>

			{
				latest && (
					<a class="plate" href={url(`/blog/${latest.post.id}/`)}>
						<div class="plate-inner">
							<span class="kicker plate-kicker">Cover Story · {latest.no}</span>
							<h2 class="display plate-title">{latest.post.data.title}</h2>
							<p class="plate-desc">{latest.post.data.description}</p>
							<span class="kicker plate-date">
								<FormattedDate date={latest.post.data.pubDate} />
							</span>
						</div>
					</a>
				)
			}

			<p class="deck">{TAGLINE}</p>

			<hr class="rule" />
			<div class="toc">
				<div class="toc-col">
					<h3 class="toc-head">In This Issue</h3>
					{
						latest && (
							<a class="toc-item" href={url(`/blog/${latest.post.id}/`)}>
								{latest.post.data.title}
							</a>
						)
					}
				</div>
				<div class="toc-col">
					<h3 class="toc-head">Back Issues</h3>
					{
						backIssues.length === 0 ? (
							<span class="toc-item toc-item--muted">창간호입니다. 과월호 없음.</span>
						) : (
							backIssues.map(({ post, no }) => (
								<a class="toc-item" href={url(`/blog/${post.id}/`)}>
									<span class="toc-no">{no}</span> {post.data.title}
								</a>
							))
						)
					}
					<a class="toc-item toc-item--muted" href={url('/blog')}>전체 목차 →</a>
				</div>
				<div class="toc-col">
					<h3 class="toc-head">Volume No. {issues.length}</h3>
					<span class="toc-item toc-item--muted">{edition}</span>
				</div>
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	.cover {
		position: relative;
		max-width: var(--page-max);
		margin: 0 auto;
		padding: clamp(2.5rem, 7vh, 5rem) var(--page-pad) 0;
		text-align: center;
	}
	.side-tab {
		position: absolute;
		top: 46%;
		width: clamp(1.5rem, 4vw, 3.5rem);
		height: 2.6rem;
		background: var(--ink);
	}
	.side-tab--left { left: 0; }
	.side-tab--right { right: 0; }

	.publisher {
		margin: 0 0 1.6rem;
	}
	.masthead {
		font-size: clamp(3.2rem, 11vw, 8rem);
		display: grid;
	}
	.masthead-layer {
		grid-area: 1 / 1;
		display: flex;
		align-items: center;
		justify-content: center;
	}
	/*
	   Page-turn wipe. Three stacked layers on one grid cell:
	     1. English (base, always there)
	     2. Korean — wipes in right-to-left, then holds
	     3. English again — wipes in right-to-left over the Korean, then holds
	   At the loop point both moving layers snap back to hidden, which is
	   invisible because layer 3 is pixel-identical to layer 1.
	   Each moving layer carries the paper background so it occludes the
	   layer beneath; the mask edge is a soft gradient, so no visible seam.
	*/
	.masthead-kr,
	.masthead-en-return {
		background: var(--paper);
		/* bleed past the grid cell so glyph descenders underneath are covered too */
		margin: -0.18em;
		mask-image: linear-gradient(100deg, transparent 50%, #000 50%);
		mask-size: 250% 100%;
		mask-repeat: no-repeat;
		mask-position: 0% 0;
		-webkit-mask-image: linear-gradient(100deg, transparent 50%, #000 50%);
		-webkit-mask-size: 250% 100%;
		-webkit-mask-repeat: no-repeat;
		-webkit-mask-position: 0% 0;
	}
	.masthead-kr {
		font-family: 'Nanum Myeongjo', 'Noto Serif KR', var(--serif);
		font-weight: 400;
		letter-spacing: 0.04em;
		animation: turn-in-kr 11s infinite;
	}
	.masthead-en-return {
		animation: turn-in-en 11s infinite;
	}
	@keyframes turn-in-kr {
		0% {
			mask-position: 0% 0;
			-webkit-mask-position: 0% 0;
			animation-timing-function: ease-in-out;
		}
		38%,
		100% {
			mask-position: 100% 0;
			-webkit-mask-position: 100% 0;
		}
	}
	@keyframes turn-in-en {
		0%,
		50% {
			mask-position: 0% 0;
			-webkit-mask-position: 0% 0;
			animation-timing-function: ease-in-out;
		}
		88%,
		100% {
			mask-position: 100% 0;
			-webkit-mask-position: 100% 0;
		}
	}
	@media (prefers-reduced-motion: reduce) {
		.masthead-kr,
		.masthead-en-return {
			display: none;
		}
	}
	.subtitle {
		margin: 1.4rem 0 3rem;
	}

	.plate {
		display: block;
		background: var(--ink);
		color: var(--paper);
		margin: 0 auto;
		max-width: 780px;
		padding: clamp(2.5rem, 6vw, 5rem) clamp(1.5rem, 5vw, 4rem);
		transition: transform 0.25s ease;
	}
	.plate:hover {
		transform: translateY(-3px);
	}
	.plate-inner {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1.4rem;
	}
	.plate-kicker {
		color: var(--paper);
		opacity: 0.7;
	}
	.plate-title {
		color: var(--paper);
		font-size: clamp(1.8rem, 4.5vw, 3.1rem);
		font-weight: 500;
	}
	.plate-desc {
		margin: 0;
		max-width: 46ch;
		font-style: italic;
		opacity: 0.75;
		line-height: 1.8;
	}
	.plate-date {
		color: var(--paper);
		opacity: 0.55;
	}

	.deck {
		font-size: 1.15rem;
		font-style: italic;
		max-width: 46ch;
		margin: 3rem auto 3.5rem;
		color: var(--ink-soft);
	}

	.toc {
		display: grid;
		grid-template-columns: 1fr 1.4fr 0.8fr;
		gap: 2.5rem;
		padding: 1.8rem 0 1rem;
		text-align: left;
	}
	.toc-head {
		font-size: 1.05rem;
		font-weight: 700;
		margin: 0 0 0.7rem;
	}
	.toc-item {
		display: block;
		font-family: var(--sans);
		font-size: 0.85rem;
		line-height: 1.6;
		margin-bottom: 0.55rem;
		color: var(--ink-soft);
	}
	a.toc-item:hover {
		opacity: 0.5;
	}
	.toc-item--muted {
		color: var(--ink-faint);
	}
	.toc-no {
		font-size: 0.7rem;
		letter-spacing: 0.1em;
		color: var(--ink-faint);
	}

	@media (max-width: 720px) {
		.toc {
			grid-template-columns: 1fr;
			gap: 1.8rem;
		}
		.side-tab {
			display: none;
		}
	}
</style>
