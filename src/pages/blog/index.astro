---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE, issueNumber, url } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => a.data.pubDate.valueOf() - b.data.pubDate.valueOf(),
);
const issues = posts
	.map((post, i) => ({ post, no: issueNumber(i + 1) }))
	.reverse();
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={`Index — ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header compact />
		<main>
			<div class="index-bar">
				<span class="kicker">{issues[0]?.no ?? '#000'}</span>
				<span class="kicker">The Index</span>
				<span class="kicker">{issues[0]?.no ?? '#000'}</span>
			</div>

			<h1 class="display index-title">Index</h1>

			<section class="entries">
				{
					issues.map(({ post, no }) => (
						<a class="entry" href={url(`/blog/${post.id}/`)}>
							<span class="kicker kicker--faint entry-no">{no}</span>
							<div class="entry-body">
								<h2 class="display entry-title">{post.data.title}</h2>
								<p class="entry-desc">{post.data.description}</p>
							</div>
							<span class="kicker kicker--faint entry-date">
								<FormattedDate date={post.data.pubDate} />
							</span>
						</a>
					))
				}
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		max-width: var(--page-max);
		margin: 0 auto;
		padding: 2.5rem var(--page-pad) 0;
	}
	.index-bar {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		padding-bottom: 0.8rem;
		border-bottom: 1px solid var(--rule);
	}
	.index-title {
		font-size: clamp(4rem, 16vw, 11rem);
		text-align: center;
		text-transform: uppercase;
		margin: 2rem 0 3.5rem;
	}
	.entries {
		border-top: 3px solid var(--rule);
	}
	.entry {
		display: grid;
		grid-template-columns: 5rem 1fr auto;
		gap: 2rem;
		align-items: baseline;
		padding: 2.2rem 0;
		border-bottom: 1px solid var(--rule-faint);
	}
	.entry:hover .entry-title {
		font-style: italic;
	}
	.entry-title {
		font-size: clamp(1.5rem, 3.5vw, 2.3rem);
		font-weight: 500;
	}
	.entry-desc {
		margin: 0.7rem 0 0;
		color: var(--ink-soft);
		font-size: 0.98rem;
		max-width: 60ch;
	}
	@media (max-width: 600px) {
		.entry {
			grid-template-columns: 1fr;
			gap: 0.6rem;
		}
	}
</style>
