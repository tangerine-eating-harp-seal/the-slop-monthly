---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { url } from '../consts';

type Props = CollectionEntry<'blog'>['data'] & { issueNo?: string };

const { title, description, pubDate, updatedDate, heroImage, issueNo = '#000' } = Astro.props;
---

<html lang="ko">
	<head>
		<BaseHead title={title} description={description} />
	</head>

	<body>
		<Header compact />
		<main>
			<article>
				<div class="post-bar">
					<span class="kicker">{issueNo}</span>
					<span class="kicker">New Post</span>
					<span class="kicker">{issueNo}</span>
				</div>

				<header class="post-head">
					<h1 class="display post-title">{title}</h1>
					<p class="post-desc">{description}</p>
					<div class="kicker kicker--faint post-meta">
						<FormattedDate date={pubDate} />
						{
							updatedDate && (
								<span class="updated">
									· Updated <FormattedDate date={updatedDate} />
								</span>
							)
						}
					</div>
				</header>

				{
					heroImage && (
						<div class="hero-image">
							<Image width={1020} height={510} src={heroImage} alt="" />
						</div>
					)
				}

				<div class="prose">
					<slot />
				</div>

				<nav class="post-end">
					<hr class="rule" />
					<a class="kicker" href={url('/blog')}>← Back to Index</a>
				</nav>
			</article>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		max-width: var(--page-max);
		margin: 0 auto;
		padding: 2.5rem var(--page-pad) 0;
	}
	.post-bar {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		padding-bottom: 0.8rem;
		border-bottom: 1px solid var(--rule);
	}
	.post-head {
		text-align: center;
		padding: clamp(2.5rem, 7vw, 5rem) 0 3rem;
	}
	.post-title {
		font-size: clamp(2.4rem, 7vw, 5rem);
	}
	.post-desc {
		font-style: italic;
		font-size: 1.15rem;
		color: var(--ink-soft);
		max-width: 52ch;
		margin: 1.8rem auto 0;
	}
	.post-meta {
		margin-top: 2rem;
	}
	.hero-image {
		border: 1px solid var(--rule);
		padding: 0.6rem;
		background: #fff;
		max-width: 860px;
		margin: 0 auto 3rem;
	}
	.prose {
		max-width: 68ch;
		margin: 0 auto;
		font-size: 1.05rem;
	}
	.post-end {
		max-width: 68ch;
		margin: 4rem auto 0;
	}
	.post-end a {
		display: inline-block;
		margin-top: 1.2rem;
	}
	.post-end a:hover {
		opacity: 0.5;
	}
</style>
